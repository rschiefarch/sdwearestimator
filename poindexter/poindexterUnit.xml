<dexUnit>
    <name>sdestimator</name>
    <appType>rust std</appType>
    <!-- baseDir>../</baseDir -->
    <readOnly>true</readOnly>
    <!-- specBase>/src/main/java/au/com/apirosolutions/acme/srv/spec</specBase -->
    <description>
        small binary that runs on linux and estimates block write cound for sd card that a filesystem is mounted on.
    </description>
    <ictRefs>
        <ictRef>
            <name>ROOT</name>
            <description>root info for rust app</description>
            <path>./ict/ROOT.txt</path>
        </ictRef>
    </ictRefs>
    <scanPrefixes>
        <scanPrefix>/src</scanPrefix>
        <scanPrefix>/.cargo</scanPrefix>
    </scanPrefixes>
    <noScanPrefixes>
        <noScanPrefix>/target</noScanPrefix>
        <noScanPrefix>/etc</noScanPrefix>
        <noScanPrefix>/.</noScanPrefix>
    </noScanPrefixes>
</dexUnit>